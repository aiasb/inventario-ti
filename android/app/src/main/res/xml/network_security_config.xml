<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Permite HTTP para redes locais (servidor Docker na mesma rede WiFi) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
